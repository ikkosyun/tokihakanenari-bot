# ローカルで --dry-run するときにこのファイルを .env にコピーして値を埋める
# （.env はgit管理対象外。本番はGitHub Secretsに登録する）

GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --publish / GitHub Actions でのみ必要
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_API_VERSION=v21.0
GH_PAGES_BASE_URL=https://yourusername.github.io/tokihakanenari-bot

# refresh_token.py でのみ必要（Meta app dashboard の
# Instagram > API setup with Instagram login に表示される値）
IG_APP_SECRET=

# ローカルで --dry-run するときにこのファイルを .env にコピーして値を埋める
# （.env はgit管理対象外。本番はGitHub Secretsに登録する）

GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# 任意: リール動画のナレーション音声(Gemini TTS)関連。省略時はコード内のデフォルト値を使う
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore

# --publish / GitHub Actions でのみ必要
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_API_VERSION=v21.0
GH_PAGES_BASE_URL=https://yourusername.github.io/tokihakanenari-bot

# refresh_token.py でのみ必要（Meta app dashboard の
# Instagram > API setup with Instagram login に表示される値）
IG_APP_SECRET=

# 任意: 設定すると --publish 時に生成画像をSlackにも通知する
# (Slack Appの「Incoming Webhooks」で、通知したいDM/チャンネル宛に発行したURL)
SLACK_WEBHOOK_URL=
